# Server
PORT=9900

# Require Authorization header on mock API calls
SALLA_MOCK_REQUIRE_AUTH=true
# Leave empty to only require the header, not the exact value
SALLA_MOCK_EXPECTED_TOKEN=

# Mock merchant/user data returned by /oauth2/user/info
SALLA_MOCK_MERCHANT_ID=1793723426
SALLA_MOCK_MERCHANT_NAME=Mock Merchant
SALLA_MOCK_USER_NAME=Mock User
SALLA_MOCK_MOBILE=554505052
SALLA_MOCK_MOBILE_CODE=+966
SALLA_MOCK_EMAIL=mock.user22@example.com
SALLA_MOCK_SCOPE=read write

# Optional: path to a JSON order snapshot file
SALLA_MOCK_ORDER_TEMPLATE=

# Where the mock will send webhooks
CORE_WEBHOOK_URL=https://brakeless-boozily-haven.ngrok-free.dev/integrations/salla/webhooks/
ORDER_WEBHOOK_URL=https://brakeless-boozily-haven.ngrok-free.dev/order/v1/salla/

# Must match the token configured in Core/Order (SALLA_WEBHOOK_TOKEN)
SALLA_WEBHOOK_TOKEN=dev_salla_token

# Webhook sender behavior
SALLA_MOCK_WEBHOOK_TIMEOUT=10000
SALLA_MOCK_SEND_CHARGE_SUCCEEDED=false

# Optional: used by /mock/scenario if app_id not provided
TECHRAR_APP_ID=90